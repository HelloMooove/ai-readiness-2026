# --- Airtable (existing public form submission) ---
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# --- Supabase (admin auth + future submissions storage) ---
# From Supabase Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Admin allowlist ---
# Comma-separated list of emails allowed to sign in to /admin.
# If unset, defaults to hello@mooove.live.
ADMIN_EMAILS=hello@mooove.live
